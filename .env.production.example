# Copy this file to .env before running docker compose.
# Docker Compose automatically reads .env for build args and runtime variables.

# Public URL where nginx should listen on the host.
NGINX_PORT=80

# Laravel JSON:API backend. Include /v1.
# Keep API_BASE_URL and NEXT_PUBLIC_API_BASE_URL the same unless you know
# the browser and server containers must use different backend addresses.
API_BASE_URL=https://your-api-domain.example/v1
NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.example/v1

# Laravel storage/media base URL. Do not include /storage.
STORAGE_BASE_URL=https://your-api-domain.example
NEXT_PUBLIC_STORAGE_BASE_URL=https://your-api-domain.example

# Public canonical origin of the storefront (no trailing slash, no path).
# REQUIRED for correct SEO — drives canonical URLs, hreflang alternates,
# sitemap.xml, robots.txt, Open Graph tags and JSON-LD structured data.
# Must be the exact production domain users visit.
NEXT_PUBLIC_SITE_URL=https://your-storefront-domain.example

# Store contact information shown on the contact page.
CONTACT_MOBILE_PHONE=0912-9333034
CONTACT_OFFICE_PHONE=021-22011507
CONTACT_HOURS_OPEN=08:00
CONTACT_HOURS_CLOSE=21:00

# Checkout delivery map provider: "osm" (default, free, key-less) or "neshan".
# Leave unset/"osm" to use OpenStreetMap + Nominatim with no keys.
NEXT_PUBLIC_MAP_PROVIDER=osm
# Neshan keys (only needed when NEXT_PUBLIC_MAP_PROVIDER=neshan). Get them free
# at https://platform.neshan.org — note they are TWO different keys:
#   - map key  : renders tiles in the browser (safe to expose).
#   - service key: reverse-geocoding REST API, kept server-side only.
NEXT_PUBLIC_NESHAN_MAP_KEY=
NESHAN_SERVICE_KEY=
# Optional Neshan base style; unset = "standard-day" in light, "standard-night"
# in dark. Other options: dreamy, neshan, standard-day, standard-night.
NEXT_PUBLIC_NESHAN_MAP_TYPE=
